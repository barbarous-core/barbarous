FROM quay.io/fedora/fedora-coreos:stable

# Inject Repositories natively
RUN echo -e "[rpmfusion-free]\nname=RPM Fusion for Fedora \$releasever - Free\nmetalink=https://mirrors.rpmfusion.org/metalink?repo=free-fedora-\$releasever&arch=\$basearch\nenabled=1\nmetadata_expire=7d\ngpgcheck=0" > /etc/yum.repos.d/rpmfusion-free.repo && \
    echo -e "[rpmfusion-nonfree]\nname=RPM Fusion for Fedora \$releasever - Nonfree\nmetalink=https://mirrors.rpmfusion.org/metalink?repo=nonfree-fedora-\$releasever&arch=\$basearch\nenabled=1\nmetadata_expire=7d\ngpgcheck=0" > /etc/yum.repos.d/rpmfusion-nonfree.repo && \
    echo -e "[zfs]\nname=ZFS on Linux for Fedora \$releasever\nbaseurl=http://download.zfsonlinux.org/fedora/\$releasever/\$basearch/\nenabled=1\nmetadata_expire=7d\ngpgcheck=0" > /etc/yum.repos.d/zfs.repo

# Explicitly download and install all the layered packages at build time.
# If a package fails here, the build halts. This guarantees the ISO will never boot broken.
RUN rpm-ostree install -y \
    ncdu p7zip p7zip-plugins unzip zstd jq htop powertop pass stow usbutils \
    pciutils pcp smartmontools nvme-cli lm_sensors lsof strace iotop gnupg2 \
    zsh tmux ncurses wavemon firewalld wireguard-tools nmap mtr nmap-ncat \
    socat tcpdump podman flatpak distrobox gcc gcc-c++ make python3 ruby \
    android-tools ffmpeg cockpit podman-compose libvirt-client \
    libvirt-daemon-kvm virt-install zfs duperemove samba mergerfs nfs-utils \
    rclone snapraid sanoid \
    && ostree container commit
