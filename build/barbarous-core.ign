  "systemd": {
    "units": [
      {
        "contents": "[Unit]\nDescription=Layer additional packages for Barbarous Core\nAfter=network-online.target\nWants=network-online.target\nBefore=systemd-user-sessions.service\nConditionFirstBoot=yes\n\n[Service]\nType=oneshot\n# We iterate over the requested packages and only append them to the install command \n# if they are not already installed natively in the Fedora CoreOS base image to prevent failures.\nExecStart=/bin/bash -c '\\\n  PACKAGES=\"ncdu p7zip p7zip-plugins unzip zstd jq htop powertop pass stow usbutils pciutils pcp \\\n  smartmontools nvme-cli lm_sensors lsof strace iotop gnupg2 zsh tmux ncurses \\\n  wavemon firewalld wireguard-tools nmap mtr nmap-ncat socat tcpdump \\\n  podman flatpak distrobox gcc gcc-c++ make python3 ruby android-tools \\\n  ffmpeg cockpit podman-compose libvirt-client libvirt-daemon-kvm virt-install \\\n  zfs duperemove samba mergerfs nfs-utils rclone snapraid sanoid\"; \\\n  TO_INSTALL=\"\"; \\\n  for pkg in $PACKAGES; do \\\n    if ! rpm -q $pkg \u003e /dev/null 2\u003e\u00261; then \\\n      TO_INSTALL=\"$TO_INSTALL $pkg\"; \\\n    fi; \\\n  done; \\\n  if [ -n \"$TO_INSTALL\" ]; then \\\n    echo \"Installing packages: $TO_INSTALL\"; \\\n    rpm-ostree install -y --idempotent $TO_INSTALL; \\\n  else \\\n    echo \"All requested packages are already in the base OS.\"; \\\n  fi'\n\n# Reboot the system to apply the new ostree layer automatically.\nExecStartPost=/usr/bin/systemctl reboot\n\n[Install]\nWantedBy=multi-user.target\n",
        "enabled": true,
        "name": "rpm-ostree-install.service"
      }
    ]
  }
}
