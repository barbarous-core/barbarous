  },
  "systemd": {
    "units": [
      {
        "contents": "[Unit]\nDescription=Install Local RPM Assets\nAfter=local-fs.target\nConditionPathExists=/var/lib/barbarous-assets/rpms\n[Service]\nType=oneshot\n# Pipe output directly to the primary console so it shows before login\nStandardOutput=tty\nStandardError=tty\nTTYPath=/dev/tty1\nExecStart=/usr/bin/rpm-ostree install --apply-live --idempotent /var/lib/barbarous-assets/rpms/*.rpm\n[Install]\nWantedBy=multi-user.target\n",
        "enabled": true,
        "name": "install-assets.service"
      },
      {
        "dropins": [
          {
            "contents": "[Unit]\n# Wait for the toolkit to be ready before allowing login\nAfter=install-assets.service\n[Service]\nExecStart=\nExecStart=-/sbin/agetty --autologin barbarous --noclear --noissue %I $TERM\n",
            "name": "autologin.conf"
          }
        ],
        "name": "getty@tty1.service"
      }
    ]
  }
}
