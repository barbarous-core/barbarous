{
  "ignition": {
    "version": "3.4.0"
  },
  "storage": {
    "files": [
      {
        "path": "/etc/profile.d/99-barbarous.sh",
        "contents": {
          "source": "data:text/plain;base64,"
        },
        "mode": 493
      },
      {
        "path": "/etc/os-release",
        "mode": 420,
        "contents": {
          "source": "data:text/plain;base64,"
        },
        "overwrite": true
      }
    ]
  },
  "passwd": {
    "users": [
      {
        "name": "barbarous",
        "passwordHash": "$6$s/nMrRp1SpMNsTSt$UqoutdmAD/ycT27.4KUgjVcwRCXhhoUGkhac5JY5tsW1qENwP0.nUDt3cFHbB6VT961GlecHX1QytlqcYm6Y4/",
        "groups": [
          "wheel",
          "sudo"
        ],
        "shell": "/bin/bash"
      }
    ]
  },
  "systemd": {
    "units": [
      {
        "name": "getty@tty1.service",
        "dropins": [
          {
            "name": "autologin.conf",
            "contents": "[Service]\nExecStart=\nExecStart=-/usr/sbin/agetty --autologin barbarous --noclear --noissue %I $TERM\n"
          }
        ]
      }
    ]
  }
}
